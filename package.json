{
  "name": "scenecraft",
  "version": "0.1.0",
  "description": "Generate cinematic video prompts from text, books, and images using AI",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "scenecraft": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "video",
    "prompt",
    "gemini",
    "ai",
    "veo",
    "scene",
    "cinematic",
    "cli"
  ],
  "author": "Sunil",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunil-dhaka/scenecraft.git"
  },
  "bugs": {
    "url": "https://github.com/sunil-dhaka/scenecraft/issues"
  },
  "homepage": "https://github.com/sunil-dhaka/scenecraft#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "@google/genai": "^1.39.0",
    "chalk": "^5.6.2",
    "clipboardy": "^5.1.0",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.0",
    "epub2": "^3.0.2",
    "ora": "^9.1.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
